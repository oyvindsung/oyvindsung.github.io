---
import { themeConfig } from '~/.config'

const { latex } = themeConfig

const mathjax = latex.mathjax
const mathJaxConfig = `window.MathJax = ${JSON.stringify({
  tex: {
    inlineMath: [
      ['$', '$'],
      ['\\(', '\\)'],
    ],
    displayMath: [
      ['$$', '$$'],
      ['\\[', '\\]'],
    ],
    processEscapes: true,
    tags: 'ams',
  },
})}`
---

{
  mathjax && (
    <>
      <script is:inline set:html={mathJaxConfig} />
      <script is:inline async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" />
    </>
  )
}
